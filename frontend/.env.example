# ── Google Maps ──────────────────────────────────────────────────────────────
# Get your key from https://console.cloud.google.com/ → APIs & Services
# Make sure "Maps JavaScript API" is enabled.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Backend URLs ──────────────────────────────────────────────────────────────
# Development (local FastAPI server)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/live

# Production (set these in the Vercel dashboard → Settings → Environment Variables)
# VITE_API_URL=https://your-render-service.onrender.com
# VITE_WS_URL=wss://your-render-service.onrender.com/ws/live
